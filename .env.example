# Servidor
SERVER_PORT=8080

# Base de datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ecommerce
DB_USER=postgres
DB_PASSWORD=postgres

# JPA / Hibernate
JPA_DDL_AUTO=update
JPA_SHOW_SQL=true

# OAuth2 - Google
OAUTH2_CLIENT_ID=tu-google-client-id
OAUTH2_CLIENT_SECRET=tu-google-client-secret

# OpenAPI / Swagger
SPRINGDOC_API_TITLE=Ecommerce API
SPRINGDOC_API_DESCRIPTION=API REST de e-commerce
SPRINGDOC_API_VERSION=0.0.1
